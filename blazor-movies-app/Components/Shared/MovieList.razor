@using blazor_movies_app.Utils
@inject IJSRuntime jSRuntime

<GenericList List="Movies">
    <MovieItem @key="context.Id" Movie="context" RemoveMovie="RemoveMovie" />
</GenericList>

@code {

    [Parameter, EditorRequired] public List<Movie>? Movies { get; set; }

    private async Task RemoveMovie(Movie movie)
    {
        var message =  $"¿Desea eliminar la pelicula {movie.Title}?";
        var confirm = await jSRuntime.Confirm(message);

        if (confirm)
        {
            Movies!.Remove(movie);
        }

    }

}
