
<button @onclick="OnClick" class="@CssClass" disabled="@Disabled" @attributes="AdditionalAttributes">@ChildContent</button>

@code {
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public Variante Variante { get; set; } = Variante.Primary;
    [Parameter] public Size Size { get; set; } = Size.Md;
    [Parameter] public EventCallback OnClick { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; } = @<text>Sumbit</text>;

    [Parameter(CaptureUnmatchedValues = true)] public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private void EventClick()
    {
        Console.WriteLine("Hello World!");
    }

    private string CssClass
    {
        get
        {

            var cssClassesOfDad = string.Empty;

            if (AdditionalAttributes != null && AdditionalAttributes.ContainsKey("class"))
            {
                cssClassesOfDad = AdditionalAttributes["class"].ToString()!;
            }


            string[] classes = [
                "btn",
                Variante switch {
                    Variante.Primary => "btn-primary",
                    Variante.Secondary => "btn-secondary",
                    Variante.Exit => "btn-success",
                    Variante.Warning => "btn-warning",
                    Variante.Error => "btn-danger",
                    _ => "btn-primary"
                },
                Size switch {
                    Size.Sm => "btn-sm",
                    Size.Md => "btn-md",
                    Size.Lg => "btn-lg",
                    _ => "btn-md",
                },
                cssClassesOfDad
            ];

            return string.Join(" ", classes);
        }
    }
}
